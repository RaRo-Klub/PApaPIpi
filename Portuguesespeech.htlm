<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Fala Português! 🇧🇷</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,700;1,400&family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --g: #009C3B;
    --y: #FFDF00;
    --b: #002776;
    --bg: #F5F0E8;
    --card: #FFFFFF;
    --text: #1A1A2E;
    --muted: #7A7A8C;
    --radius: 22px;
    --shadow: 0 10px 40px rgba(0,39,118,0.13);
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

  body {
    font-family: 'Outfit', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100dvh;
    overflow-x: hidden;
  }

  /* ── HEADER ── */
  .header {
    background: var(--g);
    padding: 52px 22px 44px;
    position: relative;
    overflow: hidden;
  }
  .header-blob { position: absolute; border-radius: 50%; opacity: .18; }
  .header-blob.a { width: 220px; height: 220px; background: var(--y); top: -60px; right: -50px; }
  .header-blob.b { width: 120px; height: 120px; background: var(--b); bottom: -30px; left: 20px; }

  .header-top {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 18px; position: relative; z-index: 1;
  }
  .flag-strip { display: flex; gap: 5px; align-items: center; }
  .flag-dot { width: 11px; height: 11px; border-radius: 50%; box-shadow: 0 1px 4px rgba(0,0,0,.25); }
  .score-pill {
    background: rgba(255,255,255,.2); border: 1.5px solid rgba(255,255,255,.35);
    color: #fff; border-radius: 999px; padding: 5px 14px;
    font-size: 13px; font-weight: 600; display: flex; align-items: center; gap: 5px;
  }
  .header h1 { font-family: 'Fraunces', serif; font-size: 34px; color: #fff; line-height: 1.1; position: relative; z-index: 1; }
  .header h1 em { font-style: italic; color: var(--y); }
  .header p { color: rgba(255,255,255,.72); font-size: 13px; font-weight: 300; margin-top: 5px; position: relative; z-index: 1; }
  .header-wave { position: absolute; bottom: -1px; left: 0; right: 0; height: 32px; }

  /* ── TABS ── */
  .tabs-wrap { padding: 20px 16px 8px; overflow-x: auto; display: flex; gap: 8px; scrollbar-width: none; }
  .tabs-wrap::-webkit-scrollbar { display: none; }
  .tab {
    flex-shrink: 0; padding: 8px 18px; border-radius: 999px;
    border: 2px solid #E0D8CC; background: transparent;
    font-family: 'Outfit', sans-serif; font-size: 13px; font-weight: 600;
    color: var(--muted); cursor: pointer; transition: all .2s;
  }
  .tab.active { background: var(--b); border-color: var(--b); color: #fff; }

  /* ── MODE SWITCHER ── */
  .mode-wrap { padding: 8px 16px 16px; }
  .mode-switch { display: flex; background: #E8E2D8; border-radius: 14px; padding: 4px; gap: 3px; }
  .mode-btn {
    flex: 1; padding: 10px 6px; border-radius: 11px; border: none; background: transparent;
    font-family: 'Outfit', sans-serif; font-size: 12px; font-weight: 600; color: #999;
    cursor: pointer; transition: all .2s; display: flex; flex-direction: column; align-items: center; gap: 2px;
  }
  .mode-btn .mico { font-size: 18px; line-height: 1; }
  .mode-btn.active { background: var(--card); color: var(--b); box-shadow: 0 3px 12px rgba(0,0,0,.1); }

  /* ── MAIN ── */
  .main { padding: 0 16px 100px; }

  /* ── FLASH CARD ── */
  .card-scene { perspective: 900px; margin-bottom: 14px; }
  .flashcard {
    width: 100%; min-height: 230px; position: relative;
    transform-style: preserve-3d; transition: transform .55s cubic-bezier(.4,0,.2,1);
    cursor: pointer; border-radius: var(--radius);
  }
  .flashcard.flipped { transform: rotateY(180deg); }
  .card-face {
    position: absolute; inset: 0; border-radius: var(--radius);
    backface-visibility: hidden; -webkit-backface-visibility: hidden;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 30px 24px; box-shadow: var(--shadow); overflow: hidden;
  }
  .card-front { background: linear-gradient(145deg, var(--b) 0%, #003d99 100%); color: #fff; }
  .card-front::before {
    content: ''; position: absolute; width: 200px; height: 200px; border-radius: 50%;
    background: rgba(255,255,255,.05); top: -60px; right: -60px;
  }
  .card-front::after {
    content: ''; position: absolute; width: 100px; height: 100px; border-radius: 50%;
    background: rgba(255,223,0,.1); bottom: -20px; left: 20px;
  }
  .card-back { background: var(--card); transform: rotateY(180deg); }
  .card-back::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
    background: linear-gradient(90deg, var(--g), var(--y), var(--b));
  }
  .card-chip { font-size: 10px; font-weight: 700; letter-spacing: 2.5px; text-transform: uppercase; opacity: .55; margin-bottom: 14px; }
  .card-pt { font-family: 'Fraunces', serif; font-size: 30px; text-align: center; line-height: 1.25; margin-bottom: 10px; position: relative; z-index: 1; }
  .card-kana { font-size: 13px; opacity: .65; font-style: italic; text-align: center; position: relative; z-index: 1; }
  .card-ja { font-size: 24px; font-weight: 700; color: var(--text); text-align: center; line-height: 1.35; margin-bottom: 10px; }
  .card-note { font-size: 12px; color: var(--muted); text-align: center; background: #F2EDE4; border-radius: 8px; padding: 5px 12px; }
  .flip-hint {
    text-align: center; font-size: 12px; color: var(--muted);
    display: flex; align-items: center; justify-content: center; gap: 5px;
    margin-bottom: 10px; animation: pulse 2.5s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{opacity:.5} 50%{opacity:1} }

  /* ── NAV ROW ── */
  .nav-row { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
  .nav-btn {
    width: 50px; height: 50px; border-radius: 50%; border: 2px solid var(--b);
    background: var(--card); color: var(--b); font-size: 22px; cursor: pointer;
    display: flex; align-items: center; justify-content: center; transition: all .15s;
    flex-shrink: 0; box-shadow: 0 4px 14px rgba(0,39,118,.12);
  }
  .nav-btn:active { background: var(--b); color: #fff; transform: scale(.94); }
  .nav-btn:disabled { opacity: .25; pointer-events: none; }
  .prog-wrap { flex: 1; }
  .prog-bar { height: 5px; background: #E0D8CC; border-radius: 99px; overflow: hidden; margin-bottom: 5px; }
  .prog-fill { height: 100%; background: linear-gradient(90deg, var(--g), var(--y)); border-radius: 99px; transition: width .3s; }
  .prog-text { font-size: 12px; color: var(--muted); text-align: center; }

  /* ── QUIZ ── */
  .quiz-card {
    background: var(--card); border-radius: var(--radius); padding: 26px 20px 20px;
    box-shadow: var(--shadow); margin-bottom: 14px; position: relative; overflow: hidden;
  }
  .quiz-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
    background: linear-gradient(90deg, var(--g), var(--y), var(--b));
  }
  .quiz-q { font-family: 'Fraunces', serif; font-size: 28px; color: var(--b); text-align: center; margin-bottom: 6px; }
  .quiz-dir { font-size: 12px; color: var(--muted); text-align: center; margin-bottom: 22px; }
  .quiz-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .quiz-opt {
    padding: 14px 10px; border-radius: 14px; border: 2px solid #E8E0D4; background: #FAF7F2;
    font-family: 'Outfit', sans-serif; font-size: 13.5px; font-weight: 500;
    text-align: center; cursor: pointer; line-height: 1.35; transition: all .15s; color: var(--text);
  }
  .quiz-opt:active:not(.disabled) { transform: scale(.96); }
  .quiz-opt.correct { border-color: var(--g); background: #E6F9EE; color: #006B2B; font-weight: 700; }
  .quiz-opt.wrong { border-color: #D93025; background: #FDECEA; color: #C62828; }
  .quiz-opt.disabled { pointer-events: none; }
  .quiz-result { margin-top: 14px; padding: 12px 16px; border-radius: 12px; font-size: 14px; font-weight: 600; text-align: center; display: none; }
  .quiz-result.show { display: block; }
  .quiz-result.ok { background: #E6F9EE; color: #006B2B; }
  .quiz-result.ng { background: #FDECEA; color: #C62828; }
  .next-btn {
    width: 100%; padding: 16px; border-radius: 14px; border: none; background: var(--b);
    color: #fff; font-family: 'Outfit', sans-serif; font-size: 15px; font-weight: 700;
    cursor: pointer; letter-spacing: .3px; transition: opacity .15s;
  }
  .next-btn:active { opacity: .8; }

  /* ── LIST ── */
  .phrase-list { display: flex; flex-direction: column; gap: 10px; }
  .phrase-item {
    background: var(--card); border-radius: 18px; padding: 16px 18px 16px 22px;
    box-shadow: 0 3px 14px rgba(0,0,0,.07); display: flex; flex-direction: column; gap: 4px;
    cursor: pointer; transition: transform .15s; position: relative; overflow: hidden;
    border-left: 4px solid var(--g);
  }
  .phrase-item:active { transform: scale(.98); }
  .phrase-item-row { display: flex; align-items: center; justify-content: space-between; }
  .phrase-pt { font-family: 'Fraunces', serif; font-size: 18px; color: var(--b); }
  .phrase-ja { font-size: 13.5px; color: var(--text); font-weight: 500; }
  .phrase-kana { font-size: 11.5px; color: var(--muted); font-style: italic; }
  .speak-icon { width: 32px; height: 32px; border-radius: 50%; background: var(--bg); display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; transition: background .15s; }
  .phrase-item:active .speak-icon { background: var(--y); }

  /* ── BOTTOM NAV ── */
  .bottom-nav {
    position: fixed; bottom: 0; left: 0; right: 0;
    background: rgba(255,255,255,.95); backdrop-filter: blur(12px);
    border-top: 1px solid #EAE4DA; display: flex;
    padding: 8px 0 max(10px, env(safe-area-inset-bottom)); z-index: 100;
  }
  .bn { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 3px; font-size: 10px; font-weight: 600; color: #AAA; cursor: pointer; transition: color .15s; }
  .bn .bi { font-size: 22px; line-height: 1; }
  .bn.active { color: var(--b); }

  /* ── TOAST ── */
  .toast {
    position: fixed; top: 20px; left: 50%; transform: translateX(-50%) translateY(-80px);
    background: var(--text); color: #fff; padding: 10px 20px; border-radius: 999px;
    font-size: 13px; font-weight: 600; z-index: 999;
    transition: transform .3s cubic-bezier(.34,1.56,.64,1);
    white-space: nowrap; pointer-events: none;
  }
  .toast.show { transform: translateX(-50%) translateY(0); }
</style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <div class="header-blob a"></div>
  <div class="header-blob b"></div>
  <div class="header-top">
    <div class="flag-strip">
      <div class="flag-dot" style="background:var(--g)"></div>
      <div class="flag-dot" style="background:var(--y)"></div>
      <div class="flag-dot" style="background:var(--b)"></div>
    </div>
    <div class="score-pill">⭐ <span id="scoreTxt">0 pts</span></div>
  </div>
  <h1>Fala<br><em>Português!</em></h1>
  <p>スマホで学ぶポルトガル語会話</p>
  <svg class="header-wave" viewBox="0 0 400 32" preserveAspectRatio="none" fill="#F5F0E8">
    <path d="M0,16 C100,32 300,0 400,16 L400,32 L0,32 Z"/>
  </svg>
</div>

<!-- TABS -->
<div class="tabs-wrap" id="tabs"></div>

<!-- MODE SWITCHER -->
<div class="mode-wrap">
  <div class="mode-switch">
    <button class="mode-btn active" id="mb0" onclick="setMode('flash')"><span class="mico">📇</span>カード</button>
    <button class="mode-btn" id="mb1" onclick="setMode('quiz')"><span class="mico">🧩</span>クイズ</button>
    <button class="mode-btn" id="mb2" onclick="setMode('list')"><span class="mico">📋</span>一覧</button>
  </div>
</div>

<div class="main">
  <!-- FLASH MODE -->
  <div id="flashMode">
    <div class="flip-hint">🔄 カードをタップして日本語を確認</div>
    <div class="card-scene">
      <div class="flashcard" id="flashcard" onclick="flipCard()">
        <div class="card-face card-front">
          <div class="card-chip">ポルトガル語</div>
          <div class="card-pt" id="cPt"></div>
          <div class="card-kana" id="cKana"></div>
        </div>
        <div class="card-face card-back">
          <div class="card-chip" style="color:var(--muted)">日本語</div>
          <div class="card-ja" id="cJa"></div>
          <div class="card-note" id="cNote"></div>
        </div>
      </div>
    </div>
    <div class="nav-row">
      <button class="nav-btn" id="prevBtn" onclick="prevCard()">‹</button>
      <div class="prog-wrap">
        <div class="prog-bar"><div class="prog-fill" id="progFill" style="width:0%"></div></div>
        <div class="prog-text" id="progTxt"></div>
      </div>
      <button class="nav-btn" id="nextBtn" onclick="nextCard()">›</button>
    </div>
  </div>

  <!-- QUIZ MODE -->
  <div id="quizMode" style="display:none">
    <div class="quiz-card">
      <div class="quiz-q" id="qQ"></div>
      <div class="quiz-dir">正しい日本語訳を選んでください</div>
      <div class="quiz-grid" id="qOpts"></div>
      <div class="quiz-result" id="qRes"></div>
    </div>
    <button class="next-btn" onclick="nextQuiz()">次の問題 →</button>
  </div>

  <!-- LIST MODE -->
